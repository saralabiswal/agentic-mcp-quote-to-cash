# App mode: demo uses local seed_data, real calls documented vendor APIs.
APP_MODE=demo

# Stack selection.
CRM_PROVIDER=salesforce
OMS_PROVIDER=oracle_fom
SUB_PROVIDER=oracle_subscription
INSTALL_BASE_PROVIDER=oracle_install_base
INSTALL_BASE_ENABLED=true

# Runtime timeouts.
MCP_TIMEOUT_SECONDS=5
CONTEXT_ASSEMBLY_TIMEOUT_SECONDS=10

# Storage.
DATABASE_URL=sqlite+aiosqlite:///./audit.db

# Salesforce CRM and shared Salesforce auth.
SF_INSTANCE_URL=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_TOKEN_URL=

# MS Dynamics 365 / Dataverse.
DYNAMICS_TENANT_ID=
DYNAMICS_CLIENT_ID=
DYNAMICS_CLIENT_SECRET=
DYNAMICS_ORG_URL=

# Oracle CRM / CPQ / FOM / Subscription / Install Base.
ORACLE_CRM_BASE_URL=
ORACLE_CRM_USERNAME=
ORACLE_CRM_PASSWORD=
ORACLE_CPQ_BASE_URL=
ORACLE_CPQ_API_KEY=
ORACLE_FOM_OIC_URL=
ORACLE_FOM_USERNAME=
ORACLE_FOM_PASSWORD=
ORACLE_SUB_OIC_URL=
ORACLE_SUB_USERNAME=
ORACLE_SUB_PASSWORD=
ORACLE_IB_BASE_URL=
ORACLE_IB_API_KEY=

# Salesforce Order Management Systems / Revenue Cloud / Asset Management.
SALESFORCE_OMS_INSTANCE_URL=
SALESFORCE_REVENUE_INSTANCE_URL=
SALESFORCE_ASSET_INSTANCE_URL=
SALESFORCE_ASSET_CLIENT_ID=
SALESFORCE_ASSET_CLIENT_SECRET=

# ServiceNow CMDB Install Base.
SERVICENOW_CMDB_BASE_URL=
SERVICENOW_CMDB_USERNAME=
SERVICENOW_CMDB_PASSWORD=

# SAP S/4HANA Order Management Systems.
SAP_HOST=
SAP_CLIENT=
SAP_USERNAME=
SAP_PASSWORD=

# Zuora Order Management Systems and Subscription.
ZUORA_BASE_URL=
ZUORA_CLIENT_ID=
ZUORA_CLIENT_SECRET=

# NetSuite Order Management Systems.
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# Chargebee Subscription.
CHARGEBEE_SITE=
CHARGEBEE_API_KEY=

# Pricing guardrails.
MIN_MARGIN_FLOOR=0.18
APPROVAL_DISCOUNT_THRESHOLD=0.10
